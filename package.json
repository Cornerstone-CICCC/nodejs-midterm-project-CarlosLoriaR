{
  "name": "music-player-app",
  "version": "1.0.0",
  "description": "Music Player application with user authentication and BREAD functionality",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"astro dev\" \"ts-node src/index.ts\"",
    "build": "astro build && tsc",
    "preview": "astro preview",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "music",
    "playlist",
    "typescript",
    "express"
  ],
  "author": "Carlos",
  "license": "MIT",
  "dependencies": {
    "@astrojs/node": "^10.0.2",
    "astro": "^6.0.5",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "uuid": "^9.0.1",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.11",
    "@types/node": "^20.10.6",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
